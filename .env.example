# App
PORT=8080
APP_ENV=development
JWT_SECRET=cambia-esto-en-produccion

# PostgreSQL
POSTGRES_USER=accesspath
POSTGRES_PASSWORD=secret
POSTGRES_DB=accesspath_db

# Usada por la app directamente (dev local, apunta a localhost)
DATABASE_URL=postgres://accesspath:secret@localhost:5432/accesspath_db?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=accesspath
MINIO_USE_SSL=false
